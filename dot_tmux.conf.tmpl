set -g prefix C-b

set -g escape-time 10
set -g repeat-time 0
set -g focus-events on
set -g mouse on
setw -g mode-keys vi
setw -g automatic-rename off

# C-s as leader key
bind -n C-s switch-client -T cs

bind -T cs k { select-pane -U ; switch-client -T cs }
bind -T cs j { select-pane -D ; switch-client -T cs }
bind -T cs h { select-pane -L ; switch-client -T cs }
bind -T cs l { select-pane -R ; switch-client -T cs }

bind -T cs K { resize-pane -U 5 ; switch-client -T cs }
bind -T cs J { resize-pane -D 5 ; switch-client -T cs }
bind -T cs H { resize-pane -L 5 ; switch-client -T cs }
bind -T cs L { resize-pane -R 5 ; switch-client -T cs }

bind -T cs - split-window -fv -c "#{pane_current_path}"
bind -T cs = split-window -h -c "#{pane_current_path}"

bind -T cs t new-window -c "#{pane_current_path}"
bind -T cs w confirm-before -p "kill window #W? (y/n)" kill-window
bind -T cs Tab { next-window ; switch-client -T cs }
bind -T cs BTab { previous-window ; switch-client -T cs }
bind -T cs n { next-window ; switch-client -T cs }
bind -T cs p { previous-window ; switch-client -T cs }
bind -T cs d detach-client
bind -T cs s choose-tree -s

set -g status-position top
set -g status-bg "#181818"
set -g status-fg "#d4d4d4"
set -g status-left '#[fg=#181818,bg=#0078d4,bold] tmux #[default] '
set -g status-right ""
setw -g window-status-format "#[fg=#6e6e6e,bold] #W "
setw -g window-status-current-format "#[fg=#181818,bg=#0078d4,bold] #W "

set -g pane-border-style fg='#3e3e3e'
set -g pane-active-border-style fg='#0078d4'
set -g pane-border-lines heavy

# ref: https://blog.craftz.dog/how-to-run-claude-code-in-a-tmux-popup-window-with-persistent-sessions/
# Display lazygit
bind -T cs g display-popup -E -w 90% -h 90% -d "#{pane_current_path}" -s "bg=#0d1117" "zsh -ic 'lazygit'"
# Run Claude Code in a separate session
bind -T cs y run-shell '\
  SESSION="claude-$(echo #{pane_current_path} | md5sum | cut -c1-8)"; \
  tmux has-session -t "$SESSION" 2>/dev/null || \
  tmux new-session -d -s "$SESSION" -c "#{pane_current_path}" "claude"; \
  tmux display-popup -w80% -h80% -E "tmux attach-session -t $SESSION"'

setw -g monitor-activity off
set -g visual-activity off

set -g set-clipboard on
set-option -s copy-command 'pbcopy'
bind-key -T copy-mode-vi v { send-keys -X begin-selection }
bind-key -T copy-mode-vi C-v { send-keys -X rectangle-toggle }
bind-key -T copy-mode-vi y { send-keys -X copy-pipe }
bind-key -T copy-mode-vi Enter { send-keys -X copy-pipe }
